# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canvas (stored per-user in DB, but server-side proxy needs this)
# These are set by users in the settings page and stored encrypted in Supabase
# CANVAS_API_TOKEN=user-specific-token (stored in DB)
# CANVAS_BASE_URL=https://canvas.yourschool.edu (stored in DB)
